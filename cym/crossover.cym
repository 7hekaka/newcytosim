% Crossing microtubules
% Francois Nedelec, 2019-12-19 with Maud Formanek

set simul system
{
    dim = 3
    viscosity = 0.25
    time_step = 0.001
    steric = 1, 1000
    precondition = 0
}

set system display
{
    window_size = 1792, 768; point_value=0.001; style=3; back_color=white;
}

set space cell 
{
    shape = cylinderZ
    display = ( color=blue, 0x7777FF77; visible = 0 )
}

new cell
{
    bottom = 0
    top = 0.2
    radius = 0.5
}

set space floor 
{
    shape = cylinderZ
    display = ( back_color=0xFFFFFF55; visible = 3 )
}

new floor
{
    bottom = -0.01
    top = 0.2
    radius = 0.5
}


set space force 
{
    shape = force
    display = ( visible = 0 )
}

new force
{
    force = 0 0 -1
}

set fiber filament
{
    rigidity = 0.2
    segmentation = 0.032
    steric = 1, 0.007
    lattice = 1, 0.008
    confine = inside, 10000, cell
}

set filament display
{
    color      = 0xFFFFFFFF, 0x7F7F7FFF, 0xFFFFFF00;
    coloring   = 5;
    lines      = 5, 1, 1;
    lattice    = 3, 1, 0;
}

set tubule microtubule
{
    stiffness = 50000, 20000
    fiber = filament
}

set hand kinesin
{
    binding_rate = 10
    binding_range = 0.035
    unbinding_rate = 0.1
    unbinding_force = 3
    
    activity = walk
    unloaded_speed = 0
    stall_force = 6
    step_size = 0.008
    hold_growing_end = 1
}

set kinesin display
{
    color   = 0x000080FF;
    size    = 6;
    width   = 3.5;
}

set couple complex
{
    hand1 = kinesin
    hand2 = kinesin
    stiffness = 250
    diffusion = 20
    length = 0.030
    specificity = antiparallel
}

new microtubule
{
    length = 1
    position = 0 0 0.01
    orientation = +1 0 0
    mark = 2
}

new microtubule
{
    length = 1
    position = 0 0 0.035
    orientation = 1 2 0
    mark = 4
}

new 0 complex

run 25 system
{
    solve = 0
}

run 25 system
{
}

change kinesin { unloaded_speed = 0.1 }

run 10000 system
{
    nb_frames = 2000
}

