% Pole focusing by crosslinking motors that dwell at microtubule ends
% Francois Nedelec, Cambridge 2020-03-03

set simul system
{
    dim = 3
    viscosity = 1
    time_step = 0.001
    steric = 1, 10000
}

set system display
{
    style = 3;
    window_size = 1280, 720;
    point_value = 0.001;
    back_color = black;
    perspective = 2;
}

set space cell 
{
    shape = sphere
    display = ( visible = 0 )
}

new cell
{
    radius = 1
}


set fiber backbone
{
    rigidity     = 1
    segmentation = 0.064
    steric       = 1, 0.015
    binding_key  = 0
    activity      = grow
    growing_speed = 0, 0.1
    display = ( visible=1; )
}


set fiber filament
{
    rigidity = 1
    segmentation = 0.064
    lattice = 1, 0.008
}


set filament display
{
    color      = 0xFFFFFFFF, 0x333333FF, 0xFFFFFF00;
    coloring   = 5;
    lines      = 5, 0;
    points     = 1, 0;
    lattice    = 3, 1, 0;
}

set tubule microtubule
{
    stiffness = 20000, 10000
    fiber = filament
    bone = backbone
}

set hand dynein
{
    binding_rate = 5
    binding_range = 0.020
    unbinding_rate = 0.2
    unbinding_force = 1.5
    
    activity = kinesin
    hold_growing_end = 1
    forward_rate = 277
    backward_rate = 0.34
	unbinding_chance = 0.01
    step_size = 0.008
    stride = -1
    force = 2
}

set dynein display
{
    color = orange;
    size  = 5;
    width = 3.5;
}

set couple motor
{
    activity = crosslink
    hand1 = dynein
    hand2 = dynein
    stiffness = 150
    diffusion = 1
    length = 0.020
}

new 1 microtubule
{
    length = 1.024, 0.512
    position = rectangle 0.5 0.1 0.1
    direction = -1 0 0 blur 0.3
    equilibrate = 10
}


run 100 system
{
}

new 2000 motor
{
    attach1 = filament
}

run 2000 system
{
    nb_frames = 1000
}

