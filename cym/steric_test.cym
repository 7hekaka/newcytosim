% A test of steric interactions between fibers
% F. Nedelec, 23 Jan 2010


set simul system
{
    steric_max_range = 0.5
    steric = 1, 100, 10

    viscosity = 10
    time_step = 0.001
    kT = 0.00042
}

set space cell
{
    shape = circle
}

new cell
{
    radius = 1
}

set fiber filament
{
    rigidity = 10
    segmentation = 0.2

    steric = 1, 0.05, 0.05
    display = ( lines=3; labels=1; points=8, 1; coloring=1; )
}


new filament { length = 0.6; position = -0.5  0.05 0; direction = X; }
new filament { length = 0.6; position = -0.5 -0.05 0; direction = X; }


new filament { length = 0.6; position =  0.5  0.1 0; direction = X; }
new filament { length = 0.6; position =  0.5 -0.1 0; direction = X; }


new filament { length = 0.5; position =  0.31 0.5 0; direction =  1 0; }
new filament { length = 0.5; position = -0.31 0.5 0; direction =  1 0; }

new filament { length = 0.5; position =  0.30 0.6 0; direction = -1 0; }
new filament { length = 0.5; position = -0.30 0.6 0; direction =  1 0; }

new filament { length = 0.5; position =  0.29 0.7 0; direction = -1 0; }
new filament { length = 0.5; position = -0.29 0.7 0; direction = -1 0; }


new filament { length = 0.5; position =  0.32 -0.5 0; direction =  1 0; }
new filament { length = 0.5; position = -0.32 -0.5 0; direction =  1 0; }

new filament { length = 0.5; position =  0.30 -0.6 0; direction = -1 0; }
new filament { length = 0.5; position = -0.30 -0.6 0; direction =  1 0; }

new filament { length = 0.5; position =  0.28 -0.7 0; direction = -1 0; }
new filament { length = 0.5; position = -0.28 -0.7 0; direction = -1 0; }


set bead ball
{
    steric = 1
    confine = inside, 100
    display = ( style=5; coloring=1; )
}

new 0 ball
{
    radius = 0.1
}


run 100000 system
{
    nb_frames = 100
}

