% An antiparallel bundle extending under the action of crosslinking motors
% Francois Nedelec, Cambridge 2020-02-20

set simul system
{
    dim = 3
    viscosity = 1
    time_step = 0.001
    steric = 1, 1000
    precondition = 0
}

set system display
{
    style = 3;
    window_size = 1280, 720;
    point_value = 0.001;
    back_color = black;
    perspective = 2;
}

set space cell 
{
    shape = capsule
    display = ( visible = 0 )
}

new cell
{
    length = 0.8
    radius = 0.1
}


set fiber backbone
{
    rigidity     = 1
    segmentation = 0.128
    steric       = 1, 0.015
    binding_key  = 0
    display = ( visible=0; )
}

set fiber filament
{
    rigidity = 1
    segmentation = 0.128
    lattice = 1, 0.008
}


set filament display
{
    color      = 0xFFFFFFFF, 0x333333FF, 0xFFFFFF00;
    coloring   = 5;
    lines      = 5, 0;
    lattice    = 3, 1, 0;
}

set tubule microtubule
{
    stiffness = 10000, 5000
    fiber = filament
    bone = backbone
}

set hand ase1
{
    binding_rate = 100
    binding_range = 0.015
    unbinding_rate = 0.2
    unbinding_force = 10
    
    activity = wander
    step_size = 0.008
    diffusion = 0.1
    hold_growing_end = 1
}

set hand kinesin
{
    binding_rate = 5
    binding_range = 0.015
    unbinding_rate = 0.1
    unbinding_force = 3
    
    activity = kinesin
    forward_rate = 277
    backward_rate = 0.34
	unbinding_chance = 0.01
    force = 2
    step_size = 0.008
}

set ase1 display
{
    color = blue;
    size  = 6;
    width = 3.5;
}

set kinesin display
{
    color = green;
    size  = 5;
    width = 3.5;
}

set couple crosslinker
{
    activity = crosslink
    hand1 = ase1
    hand2 = ase1
    stiffness = 200
    diffusion = 1
    length = 0.020
    specificity = antiparallel
}

set couple complex
{
    activity = menage
    hand1 = ase1
    hand2 = ase1
    hand3 = kinesin
    stiffness = 500, 400
    diffusion = 1
    length = 0.020
    specificity = antiparallel
}

new 2 microtubule
{
    length = 0.512
    range = 0 0.022 -0.022, 0 -0.022 0.022
    %position = 0 0.025 -0.025
    rotation = X 0.25
    mark = 2
}

new 2 microtubule
{
    length = 0.512
    range = 0 -0.022 -0.022, 0 0.022 0.022
    %position = 0 -0.025 -0.025
    rotation = Y 3.1415
    mark = 4
}

new 0 microtubule
{
    length = 0.384
    position = 0 0.022 0.069
    rotation = off
}

new 400 crosslinker
{
    attach1 = filament
}

new 150 complex
{
    attach1 = filament
}

run 100 system
{
    solve = half
}

run 2000 system
{
    nb_frames = 2000
}

