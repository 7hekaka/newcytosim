% protofilaments assembled into a microtubule

% FJN, Cambridge 25.08.2019, 4.09.2019

set simul system
{
    dim = 3
    steric = 0, 100
    time_step = 0.001
    viscosity = 1
    precondition = 0
    verbose = 2
}

set system display
{
    point_size = 5
    point_value = 0.001
    window_size = 1024, 512
    %rotation = 0.707107 0 0.707107 0;
}

set space cell
{
    shape = capsule
}

new cell
{
    radius = 0.2
    length = 1.25
}

set fiber fil
{
    steric = 0
    rigidity = 1
    lattice = 1, 0.008
    segmentation = 0.032
    confine = inside, 1000
    display = ( coloring=1; style=1; back_color=dark_gray )
}

%-------------------- 13-Microtubule at origin aligned with X

new fil { family=1; length=1; direction=1; position=0  0.0088 -0.0046; origin=0; }
new fil { family=1; length=1; direction=1; position=0  0.0100  0;      origin=0.003077; }
new fil { family=1; length=1; direction=1; position=0  0.0088  0.0046; origin=0.002154; }
new fil { family=1; length=1; direction=1; position=0  0.0056  0.0082; origin=0.001231; }
new fil { family=1; length=1; direction=1; position=0  0.0012  0.0099; origin=0.000308; }
new fil { family=1; length=1; direction=1; position=0 -0.0035  0.0093; origin=0.007384; }
new fil { family=1; length=1; direction=1; position=0 -0.0074  0.0066; origin=0.006461; }
new fil { family=1; length=1; direction=1; position=0 -0.0097  0.0023; origin=0.005538; }
new fil { family=1; length=1; direction=1; position=0 -0.0097 -0.0023; origin=0.004615; }
new fil { family=1; length=1; direction=1; position=0 -0.0074 -0.0066; origin=0.003692; }
new fil { family=1; length=1; direction=1; position=0 -0.0035 -0.0093; origin=0.002769; }
new fil { family=1; length=1; direction=1; position=0  0.0012 -0.0099; origin=0.001846; }
new fil { family=1; length=1; direction=1; position=0  0.0056 -0.0082; origin=0.000923; }

%------------------- 13-Microtubule at origin, orientated -X
skip{
new fil { family=2; length=1; direction=-1; position=0 -0.0100  0;      origin=0.003077; }
new fil { family=2; length=1; direction=-1; position=0 -0.0088  0.0046; origin=0.002154; }
new fil { family=2; length=1; direction=-1; position=0 -0.0056  0.0082; origin=0.001231; }
new fil { family=2; length=1; direction=-1; position=0 -0.0012  0.0099; origin=0.000308; }
new fil { family=2; length=1; direction=-1; position=0  0.0035  0.0093; origin=0.007384; }
new fil { family=2; length=1; direction=-1; position=0  0.0074  0.0066; origin=0.006461; }
new fil { family=2; length=1; direction=-1; position=0  0.0097  0.0023; origin=0.005538; }
new fil { family=2; length=1; direction=-1; position=0  0.0097 -0.0023; origin=0.004615; }
new fil { family=2; length=1; direction=-1; position=0  0.0074 -0.0066; origin=0.003692; }
new fil { family=2; length=1; direction=-1; position=0  0.0035 -0.0093; origin=0.002769; }
new fil { family=2; length=1; direction=-1; position=0 -0.0012 -0.0099; origin=0.001846; }
new fil { family=2; length=1; direction=-1; position=0 -0.0056 -0.0082; origin=0.000923; }
new fil { family=2; length=1; direction=-1; position=0 -0.0088 -0.0046; origin=0; }
}

%------------------- 13-Microtubule shifted 35 nm in Y, orientated -X
new fil { family=3; length=1; direction=-1; position=0  0.0250  0;      origin=0.003077; }
new fil { family=3; length=1; direction=-1; position=0  0.0262  0.0046; origin=0.002154; }
new fil { family=3; length=1; direction=-1; position=0  0.0294  0.0082; origin=0.001231; }
new fil { family=3; length=1; direction=-1; position=0  0.0338  0.0099; origin=0.000308; }
new fil { family=3; length=1; direction=-1; position=0  0.0385  0.0093; origin=0.007384; }
new fil { family=3; length=1; direction=-1; position=0  0.0424  0.0066; origin=0.006461; }
new fil { family=3; length=1; direction=-1; position=0  0.0447  0.0023; origin=0.005538; }
new fil { family=3; length=1; direction=-1; position=0  0.0447 -0.0023; origin=0.004615; }
new fil { family=3; length=1; direction=-1; position=0  0.0424 -0.0066; origin=0.003692; }
new fil { family=3; length=1; direction=-1; position=0  0.0385 -0.0093; origin=0.002769; }
new fil { family=3; length=1; direction=-1; position=0  0.0338 -0.0099; origin=0.001846; }
new fil { family=3; length=1; direction=-1; position=0  0.0294 -0.0082; origin=0.000923; }
new fil { family=3; length=1; direction=-1; position=0  0.0262 -0.0046; origin=0; }




set hand kinesin
{
    binding = 9, 0.022
    unbinding = 0.5, 3

    activity = walk
    step_size = 0.008
    unloaded_speed = 0.8
    stall_force = 5

    display = ( color=green; size=7; width=5; )
    binding_key = 1
}

set couple complex
{
    hand1 = kinesin
    hand2 = kinesin
    stiffness = 500
    diffusion = 5
    length = 0.020
}

new 1000 complex

run 1000 system
{
    solve = 1
    nb_frames = 100
}

