% Growing and colliding microtubules in 3D
% Maud Formanek 13.03.2020
% FJN 15.06.2020

set simul system
{
    dim = 3
    time_step = 0.005
    viscosity = 1
    precondition = 1
    steric = 1, 5000
    tolerance = 1
    skip_free_single = 1
    display = ( point_value=0.010; )
}

set space cell
{
    shape = cylinderZ
    display = ( visible = 0; )
}

new cell
{
    length = 10
    edge = 2
    radius = 7
}

set fiber microtubule
{
    confine = inside, 250, cell
    confine2 = on, 50, cell
    steric = 1, 0.050
    rigidity = 20
    segmentation = 0.250

    activity = dynamic
    growing_speed = 0.3467
    shrinking_speed = -0.7
    growing_force = 1.4422
    hydrolysis_rate = 0.4
    
    min_length = 0.01
    persistent = 0
    
    display = ( line=8, 8; length_scale=0.1; )
}

set hand anchor
{
    binding_rate = 10
    binding_range = 0.020
    unbinding_rate = 0.02
    unbinding_force = 5.0
    display = ( size=5; color=white; )
}

set single grafted
{
    hand = anchor
    confine = off, 0, cell
    stiffness = 200
    activity = fixed
}


set hand nucleator
{
    unbinding = 0, 3
    activity = nucleate
    nucleate = 1, microtubule, ( length=0.1; direction=XY; end_state=grow; )
    display = ( size=7; color=yellow; )
}

set single creator
{
    confine = on, 0, cell
    hand = nucleator
    diffusion = 1
}

new 22000 grafted ( surface 1 )
new 300 creator ( surface 1 )

report microtubule:plus_state states.txt { verbose = 1 }

repeat 100
{
    run 5000 system
    {
        nb_frames = 1
    }
    report microtubule:plus_state states.txt { verbose = 0; }
}
